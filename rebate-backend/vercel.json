{
    "version": 2,
    "builds": [
        {
            "src": "src/main.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "src/public/**/*",
                    "public/**/*"
                ],
                "maxLambdaSize": "50mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "src/main.ts"
        },
        {
            "src": "/(.*)",
            "dest": "src/main.ts"
        }
    ]
}