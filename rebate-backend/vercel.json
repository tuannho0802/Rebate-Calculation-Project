{
    "version": 2,
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node"
        },
        {
            "src": "src/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.ts"
        },
        {
            "src": "/(styles\\.css|app\\.js|favicon\\.png)",
            "dest": "src/public/$1"
        },
        {
            "src": "/",
            "dest": "src/public/index.html"
        }
    ]
}