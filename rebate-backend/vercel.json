{
    "version": 2,
    "builds": [
        {
            "src": "rebate-backend/src/main.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "rebate-backend/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "rebate-backend/src/main.js"
        }
    ]
}